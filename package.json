{
  "name": "dit-report",
  "version": "1.0.0",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "dev": "npx wrangler pages dev public",
    "deploy": "npx wrangler pages deploy public",
    "db:init": "npx wrangler d1 execute dit-report --local --file=schema.sql",
    "db:seed": "npx wrangler d1 execute dit-report --local --file=seed.sql",
    "db:init:remote": "npx wrangler d1 execute dit-report --remote --file=schema.sql",
    "db:seed:remote": "npx wrangler d1 execute dit-report --remote --file=seed.sql",
    "db:migrate": "npx wrangler d1 execute dit-report --local --file=migrations/0001_add_multitenancy.sql",
    "db:migrate:remote": "npx wrangler d1 execute dit-report --remote --file=migrations/0001_add_multitenancy.sql"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@clerk/backend": "^3.2.2",
    "@cloudflare/puppeteer": "^1.0.6",
    "itty-router": "^5.0.23"
  },
  "devDependencies": {
    "wrangler": "^4.75.0"
  }
}
